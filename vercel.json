{
  "buildCommand": "go build -o api ./main.go",
  "outputDirectory": ".",
  "framework": "go",
  "env": {
    "GO_VERSION": "1.26.1"
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "methods": ["GET"]
    },
    {
      "src": "/(.*)",
      "dest": "/api"
    }
  ]
}
